# ==============================================================================
# 🚗 MOBILKU - E-COMMERCE APPLICATION CONFIGURATION
# ==============================================================================
# Copy this file to .env and fill in your actual values

# ==============================================================================
# DATABASE CONFIGURATION
# ==============================================================================
DATABASE_URL="mysql://root:@localhost:3306/carify"

# ==============================================================================
# JWT & AUTHENTICATION
# ==============================================================================
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRY=7d

# ==============================================================================
# PAYMENT GATEWAY - XENDIT
# ==============================================================================
# Get these from: https://dashboard.xendit.co/settings/developers/api
XENDIT_SECRET_KEY=xnd_development_xxxxx  # Replace with your actual Xendit API key
XENDIT_CALLBACK_TOKEN=your_secure_webhook_token_here  # For webhook validation - make it random & long

# ==============================================================================
# APPLICATION URLS
# ==============================================================================
# Frontend URL (for payment redirects and CORS)
FRONTEND_URL=http://localhost:3000

# Backend URL (used by frontend for API calls)
NEXT_PUBLIC_BACKEND_URL=http://localhost:3001

# ==============================================================================
# UPLOAD CONFIGURATION
# ==============================================================================
# Maximum file size in bytes (10MB = 10485760)
MAX_FILE_SIZE=10485760

# Allowed file types (comma-separated MIME types)
ALLOWED_MIME_TYPES=image/jpeg,image/png,image/webp,image/gif

# ==============================================================================
# EMAIL CONFIGURATION (for notifications)
# ==============================================================================
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_FROM=noreply@mobilku.local

# ==============================================================================
# THIRD-PARTY SERVICES
# ==============================================================================
# Google Analytics
NEXT_PUBLIC_GA_ID=

# Sentry Error Tracking
SENTRY_DSN=

# ==============================================================================
# APPLICATION SETTINGS
# ==============================================================================
NODE_ENV=development
PORT=3001

# Redis cache (if using cache)
REDIS_URL=redis://localhost:6379

# ==============================================================================
# LOGGING
# ==============================================================================
LOG_LEVEL=debug

# ==============================================================================
# DEVELOPMENT ONLY
# ==============================================================================
# Enable debug mode
DEBUG=*

# ==============================================================================
# SECURITY HEADERS
# ==============================================================================
# Allow CORS from these origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# ==============================================================================
# NOTES FOR DEPLOYMENT
# ==============================================================================
# 1. XENDIT_SECRET_KEY: Get from https://dashboard.xendit.co/settings/developers/api-keys
#    - Development: Set to "xnd_development_..." key
#    - Production: Set to production API key with "xnd_live_..."
#
# 2. XENDIT_CALLBACK_TOKEN: Use a strong random string for webhook validation
#    - Generate with: `openssl rand -base64 32`
#    - Set same value in Xendit Dashboard webhook settings
#    - Configure Xendit Webhook URL: https://your-domain.com/webhooks/xendit/invoice
#    - Add custom header: Authorization: Bearer {XENDIT_CALLBACK_TOKEN}
#
# 3. JWT_SECRET: Use strong random string
#    - Generate with: `node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"`
#
# 4. IMAGE UPLOAD PATH: Ensure 'uploads' folder exists and is writable
#    - mkdir -p ./backend/uploads
#
# 5. WebSocket: Configured on same port as backend (for real-time features)
#    - Automatically enabled when backend starts
#    - CORS configured to allow frontend connections
#
# 6. Email: Required for:
#    - Payment notifications
#    - Order status updates
#    - Password reset emails
#    - Coupon delivery
#
# 7. Production Checklist:
#    ✓ Use environment-specific DATABASE_URL
#    ✓ Generate strong JWT_SECRET
#    ✓ Use Xendit production keys
#    ✓ Set NODE_ENV=production
#    ✓ Enable HTTPS for all URLs
#    ✓ Configure CORS for production domain
#    ✓ Setup email service
#    ✓ Configure webhook callback URL in Xendit
#    ✓ Setup monitoring/error tracking (Sentry)
#    ✓ Enable file upload limits
#    ✓ Setup database backups
